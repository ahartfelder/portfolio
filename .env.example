# ── Resend (gestor de e-mail) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# E-mail que receberá as mensagens do formulário
PERSONAL_EMAIL=seu@email.com

# ── Upstash Redis (rate limiting) ─────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Vercel (preenchido automaticamente na Vercel) ─────────
# Não precisa adicionar manualmente
# VERCEL_ENV=production | preview | development
